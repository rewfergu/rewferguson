---
import Image from '~/components/common/Image.astro';
import Button from '~/components/ui/Button.astro';
import type { CallToAction } from '~/types';
import logoSvg from '~/assets/images/logo-min.svg?raw';
import Nav from '../widgets/Nav.astro';
import { getHeaderData } from '~/navigation';

export interface Props {
  id?: string;
  title?: string;
  subtitle?: string;
  tagline?: string;
  content?: string;
  actions?: string | CallToAction[];
  image?: string | any; // TODO: find HTMLElementProps
}

const {
  id,
  title = await Astro.slots.render('title'),
  subtitle = await Astro.slots.render('subtitle'),
  tagline,
  content = await Astro.slots.render('content'),
  actions = await Astro.slots.render('actions'),
  image = await Astro.slots.render('image'),
} = Astro.props;

const headerData = await getHeaderData();
import nameLogo from '~/assets/images/name.svg?raw';
---

<section class="relative md:-mt-[76px] not-prose" {...id ? { id } : {}}>
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true"></div>
  <div class="relative max-w-7xl mx-auto px-4 sm:px-6">
    <div class="pt-0 md:pt-[76px] pointer-events-none"></div>
    <div class="py-12 md:py-20">
      <div class="text-center pb-10 md:pb-16 max-w-5xl mx-auto">
        <div id="hero-name-logo" class="max-w-[640px] mx-auto flex justify-center">
          <Fragment set:html={nameLogo} />
        </div>
        <div class="w-16 mx-auto my-4">
          <Fragment set:html={logoSvg} />
        </div>
        {
          tagline && (
            <p
              class="text-secondary dark:text-primary font-heading font-[600] tracking-wide uppercase text-3xl mb-8"
              set:html={tagline}
            />
          )
        }

        <div class="bg-black p-8 rounded-2xl bg-opacity-25 max-w-[900px] mx-auto">
          <!-- <div class="justify-center hidden md:flex">
            <Nav {...headerData} className="bodyNav" />
          </div> -->

          <div class="max-w-3xl mx-auto">
            {subtitle && <p class="text-xl text-muted mb-6 dark:text-slate-300" set:html={subtitle} />}
            {
              actions && (
                <div class="max-w-xs sm:max-w-md m-auto flex flex-nowrap flex-col sm:flex-row sm:justify-center gap-4">
                  {Array.isArray(actions) ? (
                    actions.map((action) => (
                      <div class="flex w-full sm:w-auto">
                        <Button {...(action || {})} class="w-full sm:mb-0" />
                      </div>
                    ))
                  ) : (
                    <Fragment set:html={actions} />
                  )}
                </div>
              )
            }
          </div>
          {content && <Fragment set:html={content} />}
        </div>
      </div>
      <div>
        {
          image && (
            <div class="relative m-auto max-w-5xl">
              {typeof image === 'string' ? (
                <Fragment set:html={image} />
              ) : (
                <Image
                  class="mx-auto rounded-md w-full"
                  widths={[400, 768, 1024, 2040]}
                  sizes="(max-width: 767px) 400px, (max-width: 1023px) 768px, (max-width: 2039px) 1024px, 2040px"
                  loading="eager"
                  width={1024}
                  height={576}
                  {...image}
                />
              )}
            </div>
          )
        }
      </div>
    </div>
  </div>
</section>

<style is:global>
  /* Only present on pages with Hero — hides header logo name before JS runs,
     since the hero is always in view on initial load. */
  .logo-name {
    max-width: 0;
    opacity: 0;
  }
</style>

<script is:inline>
  (function () {
    var heroNameLogo = document.getElementById('hero-name-logo');
    var logoName = document.querySelector('.logo-name');

    if (!heroNameLogo || !logoName) return;

    // CSS already hides the logo. Measure natural width once on first reveal
    // by briefly removing max-width with transitions suppressed.
    var naturalWidth = null;

    var observer = new IntersectionObserver(
      function (entries) {
        var entry = entries[0];
        if (entry.isIntersecting) {
          logoName.style.maxWidth = '0';
          logoName.style.opacity = '0';
        } else {
          if (!naturalWidth) {
            logoName.style.transition = 'none';
            logoName.style.maxWidth = 'none';
            naturalWidth = logoName.scrollWidth + 'px';
            logoName.style.maxWidth = '0';
            // Re-enable transition next frame so the expand animates
            requestAnimationFrame(function () {
              logoName.style.transition = '';
              logoName.style.maxWidth = naturalWidth;
              logoName.style.opacity = '1';
            });
          } else {
            logoName.style.maxWidth = naturalWidth;
            logoName.style.opacity = '1';
          }
        }
      },
      { threshold: 0 }
    );
    observer.observe(heroNameLogo);
  })();
</script>
